[Unit]
Description=Skywatcher GitHub media sync
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/home/haggy/skywatcher
EnvironmentFile=-/home/haggy/skywatcher/.env
ExecStart=/usr/bin/flock -n /tmp/skywatcher-media-sync.lock /home/haggy/skywatcher/.venv/bin/python /home/haggy/skywatcher/github_media_sync.py --commit
